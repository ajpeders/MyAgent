# MyAgent API
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# Required for protected endpoints — leave empty for unauthenticated local dev only.
# Generate with: openssl rand -hex 32
MYDEVTEAM_API_KEY=

# Required — JWT signing secret. Server refuses to mint/verify tokens without it.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Optional — directory for SQLite DB and any other persistent state.
# Defaults to src/core/data.db (alongside the package). In Docker, mount a volume.
# MYDEVTEAM_DATA_DIR=/data

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
OLLAMA_HOST=http://localhost:11434

# Whisper (speech-to-text)
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu        # cpu | cuda | auto
# WHISPER_COMPUTE_TYPE=int8

# Voice agent push notifications (ntfy.sh or self-hosted)
# NTFY_BASE_URL=https://ntfy.sh
# NTFY_TOPIC=your-secret-topic
# NTFY_AUTH=Bearer tk_xxxx           # or "Basic <base64-user:pass>"

# Optional IMAP accounts
# IMAP_GMAIL_HOST=imap.gmail.com
# IMAP_GMAIL_USER=you@example.com
# IMAP_GMAIL_PASS=app-password
# IMAP_GMAIL_PORT=993
